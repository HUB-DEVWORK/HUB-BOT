# Telemetry ingest server — copy to .env and fill in.  cp .env.example .env
#
# REQUIRED: without a token /ingest fails closed (503) — set a long random value.
TS_INGEST_TOKEN=change-me-long-random-token
# Dashboard Basic-Auth (view/resolve issues at / ).
TS_DASH_USER=admin
TS_DASH_PASS=change-me
# Where the SQLite DB lives inside the container (mounted at /data via compose).
TS_DB_PATH=/data/telemetry.db
# Optional: Telegram alerts on each new error fingerprint.
TS_TG_BOT_TOKEN=
TS_TG_CHAT_ID=
# Escape hatch: set to 1 to allow tokenless /ingest (public — NOT recommended).
TS_ALLOW_ANONYMOUS=
